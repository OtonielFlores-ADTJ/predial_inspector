# =============================================================================
# Monitor de Pasarela de Pago - Predial Tijuana
# =============================================================================
# Copia este archivo como .env y completa los valores reales.
# ⚠️ NUNCA subas el archivo .env a un repositorio.

# ─────────────────────────────────────────────────────────────────────────────
# Credenciales del portal de pagos
# ─────────────────────────────────────────────────────────────────────────────
PORTAL_USER=usuario@correo.com
PORTAL_PASS=TU_CONTRASENA_AQUI

# ─────────────────────────────────────────────────────────────────────────────
# Configuración SMTP (alertas por correo)
# ─────────────────────────────────────────────────────────────────────────────
# Gmail requiere App Password (NO usar contraseña normal)
# https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Puede ser uno o varios separados por coma
ALERT_TO=destinatario@ejemplo.com
ALERT_FROM=tu_correo@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# Seguridad - dominio esperado de la pasarela
# ─────────────────────────────────────────────────────────────────────────────
EXPECTED_GATEWAY_DOMAIN=www.adquiramexico.com.mx

# ─────────────────────────────────────────────────────────────────────────────
# Tiempos y ejecución
# ─────────────────────────────────────────────────────────────────────────────
PAGE_TIMEOUT=90

# Intervalos dinámicos (usados si ejecutas --loop)
LOOP_INTERVAL_BUSINESS=600      # 10 min (horario laboral)
LOOP_INTERVAL_OFF=3600         # 1 hora (fuera de horario)

BUSINESS_HOUR_START=8
BUSINESS_HOUR_END=17

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
# Se recomienda usar timestamp para no sobreescribir

LOG_FILE=monitor_YYYYMMDD.log

# Ejemplo dinámico (si lo quieres fijo en el script mejor):
# LOG_FILE=monitor.log

CLAVES_TIMEOUT=120